{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@lindale/generation-core": [
        "../../packages/generation-core/src/index.ts"
      ],
      "@lindale/generation-core/*": [
        "../../packages/generation-core/src/*"
      ],
      "@lindale/generation-cafezoe": [
        "../../packages/generation-cafezoe/src/index.ts"
      ],
      "@lindale/shared": [
        "../../packages/shared/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
